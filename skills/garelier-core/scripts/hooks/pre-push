#!/bin/sh
# Garelier mechanical push guard (DEC-030) — installed into a Concierge
# worktree's hooks dir by install_concierge_guards.{sh,ps1}. git runs this
# UNCONDITIONALLY before every push, so it enforces these rules no matter what
# the agent types. It is the backstop for concierge_git_guard.{sh,ps1}.
#
# git passes "<local_ref> <local_sha> <remote_ref> <remote_sha>" lines on stdin.
#
# Hard rules (cannot be bypassed without removing the hook):
#   1. NEVER push a garelier/* branch (local-only by design; DEC — branches).
#   2. NEVER force / non-fast-forward push (history rewrite of a published ref).
#
# Exit non-zero => git aborts the push.

ZERO='0000000000000000000000000000000000000000'
status=0

# Target-push guard config (DEC-088 #5) — MAIN worktree only. A direct push of the
# project's <target> branch from the main worktree bypasses the Concierge promote
# (Guardian promote_gate + external.lock). Read the target branch + mode once from
# the first project config; the Concierge's legitimate promote push runs from its
# (linked) clipboard worktree (.git is a FILE) and is exempt.
TARGET_BRANCH=""; PROMOTE_GUARD=off
PP_TOPLEVEL=$(git rev-parse --show-toplevel 2>/dev/null || echo ".")
if [ ! -f "$PP_TOPLEVEL/.git" ]; then
  for cfg in "$PP_TOPLEVEL"/__garelier/*/_pm/setup_config.toml; do
    [ -f "$cfg" ] || continue
    [ -z "$TARGET_BRANCH" ] && TARGET_BRANCH=$(sed -n 's/^[[:space:]]*target[[:space:]]*=[[:space:]]*"\([^"]*\)".*/\1/p' "$cfg" | head -1)
    pg=$(sed -n 's/^[[:space:]]*promote_guard[[:space:]]*=[[:space:]]*"\([a-z]*\)".*/\1/p' "$cfg" | head -1)
    [ -n "$pg" ] && PROMOTE_GUARD="$pg"
    break
  done
fi

while read -r local_ref local_sha remote_ref remote_sha; do
  [ -z "$remote_ref" ] && continue

  # Rule 1: local-only garelier/* branches are never pushed.
  case "$remote_ref" in
    refs/heads/garelier/*|refs/heads/*/garelier/*)
      echo "pre-push BLOCKED: '$remote_ref' is a local-only garelier/* branch — never push it (DEC-030)." >&2
      status=1
      continue
      ;;
  esac

  # Rule 3 (DEC-088 #5): direct push of <target> from the main worktree bypasses
  # the Concierge promote gate. Opt-in [setup] promote_guard (block|warn|off,
  # default off → inert); GARELIER_ALLOW_TARGET_PUSH=1 overrides once.
  if [ -n "$TARGET_BRANCH" ] && [ "$PROMOTE_GUARD" != off ] && [ "${GARELIER_ALLOW_TARGET_PUSH:-}" != "1" ]; then
    case "$remote_ref" in
      "refs/heads/$TARGET_BRANCH"|"$TARGET_BRANCH")
        if [ "$PROMOTE_GUARD" = warn ]; then
          echo "pre-push WARNING (promote guard): direct push to target '$remote_ref' from the main worktree bypasses the Concierge promote (Guardian gate + external.lock) — DEC-088 #5." >&2
        else
          echo "pre-push BLOCKED (promote guard): direct push to target '$remote_ref' from the main worktree bypasses Concierge + the Guardian promote gate (DEC-088 #5). Promote via the Concierge; GARELIER_ALLOW_TARGET_PUSH=1 to override." >&2
          status=1
          continue
        fi
        ;;
    esac
  fi

  # A deletion (local_sha all-zero) or a brand-new ref (remote_sha all-zero) is
  # fast-forward-safe; allow non-garelier ones.
  [ "$local_sha" = "$ZERO" ] && continue
  [ "$remote_sha" = "$ZERO" ] && continue

  # Rule 2: reject a non-fast-forward (force / rewrite) — the remote tip we know
  # of must be an ancestor of what we are pushing.
  if ! git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null; then
    echo "pre-push BLOCKED: non-fast-forward (force) push to '$remote_ref' — history rewrite is forbidden (DEC-030)." >&2
    status=1
    continue
  fi
done

exit "$status"
